;; =============================================================================
;; EXHAUSTIVE CRISP TEST SUITE (PURE S-EXPR VERSION)
;; =============================================================================

;; -----------------------------------------------------------------------------
;; 1. ATOM RADIUS: Testing Number Parsing & Smallest Type Logic
;; -----------------------------------------------------------------------------
0               ; Should be U8
255             ; Should be U8
256             ; Should be U16
-128            ; Should be I8
-129            ; Should be I16
65535           ; Should be U16
4294967295      ; Should be U32
2.5             ; Should be F32
3.1415926535    ; Should be F64 (precision check)
-0.001          ; Should be F32

;; -----------------------------------------------------------------------------
;; 2. ATOM RADIUS: Strings, Symbols, and Types
;; -----------------------------------------------------------------------------
true            ; Boolean
false           ; Boolean
"the quick brown fox" ; String
""              ; Empty String
+               ; Symbol (Operator)
>>=             ; Symbol (Complex)
&global_ptr     ; Pointer Reference
id:i32          ; Typed Symbol
maybe_val:f64?  ; Typed Symbol with Optional Modifier

;; -----------------------------------------------------------------------------
;; 3. FUNCTION DEFINITIONS (Structural Context)
;; -----------------------------------------------------------------------------

;; VALID: Standard named function
(fn add (x:i32 y:i32) (
  (ret (+ x y))
))

;; VALID: Anonymous function
(fn (val:f32) (
  (ret (* val 2.0))
))

;; INVALID: Duplicate Parameters (Semantic check in validate_params)
(fn dupe (a:i32 b:i32 a:i32) (
  (ret a)
))

;; INVALID: Untyped Parameter (Grammar allows symbols, but validate_params should reject)
(fn untyped (x) (
  (ret x)
))

;; INVALID: Missing Body (Should trigger your check for pairs.next() in parse_fn)
(fn no_body (x:i32))

;; -----------------------------------------------------------------------------
;; 4. BINDINGS AND ASSIGNMENT
;; -----------------------------------------------------------------------------

;; VALID: Let with a block-like value
(let result:i32 (
  (let a:i32 10)
  (let b:i32 20)
  (ret (+ a b))
))

;; VALID: Reassignment
(set result (100))

;; INVALID: Set with no value (Contextual check in parse_set)
(set result)

;; -----------------------------------------------------------------------------
;; 5. CONTROL FLOW DISPATCH
;; -----------------------------------------------------------------------------

;; VALID: If-Else
(if (> x 10)
  ((print "Greater"))
  ((print "Lesser or Equal"))
)

;; VALID: If without Else
(if true ((ret 1)))

;; VALID: For Loop
(for i:i32 (range 0 10) (
  (print i)
))

;; VALID: Given (Pattern Matching / Switch)
(given status 
  (200 ((print "OK")))
  (404 ((print "Not Found")))
  (500 ((print "Error")))
)

;; -----------------------------------------------------------------------------
;; 6. NESTING AND COMPLEXITY
;; -----------------------------------------------------------------------------

;; Deeply nested calls
(outer (middle (inner 1 2 (deepest "val"))))

;; Block used as an expression (if your language supports this)
(let x:i32 (
  (if true ( (ret 1) ) ( (ret 0) ))
))

;; -----------------------------------------------------------------------------
;; 7. EDGE CASES AND "SANITY"
;; -----------------------------------------------------------------------------

;; Empty List: Should be handled by parse_list as an empty block or No-Op
()

;; List starting with a non-symbol (A call where the ID is another list)
((get_callback "click") arg1)

;; Comments in middle of lists
(fn ; comment
  test ; comment
  (x:i32) ; comment
  ((ret x)))

;; -----------------------------------------------------------------------------
;; 8. RETURN VARIATIONS
;; -----------------------------------------------------------------------------

(fn void_func () (
  (print "doing something")
  (ret null)      ; Explicit null
))

(fn empty_func () (
  (ret ())        ; Empty list/unit
))

(fn implicit_void () (
  (ret)           ; Variadic ret with 0 args
))

(fn multi_ret (x:i32) (
  (ret x (* x 2)) ; Returning two values
))

;; SOI/EOI Check: The file ends here. 
;; Your parse_program loop should exit without trying to parse EOI as a Node.
